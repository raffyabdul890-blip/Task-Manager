# ── Site URL ─────────────────────────────────────────────────────────────────
# Your deployed app URL. Drives the email-confirmation redirect so the signup
# link opens the real app instead of localhost. Set the same value in Vercel's
# Environment Variables, and add it to Supabase → Authentication → URL Config.

NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ── VAPID (Web Push) ──────────────────────────────────────────────────────────
# Generate once with:  npx web-push generate-vapid-keys
# Never change these after users have subscribed — it invalidates all subscriptions.

NEXT_PUBLIC_VAPID_PUBLIC_KEY=BM...your-vapid-public-key...
VAPID_PRIVATE_KEY=your-vapid-private-key...
VAPID_SUBJECT=mailto:your@email.com

# ── Supabase Edge Function secrets (set via Supabase CLI, not here) ───────────
# supabase secrets set VAPID_PUBLIC_KEY="BM..." VAPID_PRIVATE_KEY="..." VAPID_SUBJECT="mailto:..."
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY="eyJ..."
